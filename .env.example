# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NUXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Morphware Revert Contract Address
NUXT_PUBLIC_MIGRATION_REVERT_CONTRACT_ADDRESS=0x...

# Chain ID (56 for BSC Mainnet, 97 for BSC Testnet)
NUXT_PUBLIC_CHAIN_ID=56
